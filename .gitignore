# Only publish the app folders and the top-level README.
/*
!/backend/
!/frontend/
!/README.md
!/.gitignore

# Dependencies
node_modules/

# Environment files: keep examples, ignore real local secrets.
.env
.env.*
!.env.example
!.env.sample
!.env.template
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.sample
!backend/.env.template
frontend/.env
frontend/.env.*
!frontend/.env.example
!frontend/.env.sample
!frontend/.env.template

# Build outputs
dist/
build/
.next/
out/
coverage/
*.tsbuildinfo

# Python cache/build outputs
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
venv/
ENV/
env/

# Runtime/generated backend files
backend/logs/
backend/data/exports/
backend/storage/
backend/eval-reports/
backend/import_reports/

# IDE and OS files
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db

# Local Docker overrides
docker-compose.override.yml
