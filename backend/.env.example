# 应用配置
APP_NAME=ChatBI
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
# 全局路由前缀，控制器路径会拼接在后面：/{API_PREFIX}/{controller}/...
# 默认 api/v1，与前端服务层调用约定一致
API_PREFIX=api/v1

# 数据库配置 (PostgreSQL 17+)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=chatbi_user
DATABASE_PASSWORD=chatbi_password
DATABASE_NAME=chatbi_db
DATABASE_URL=postgresql://chatbi_user:chatbi_password@localhost:5432/chatbi_db

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT 认证
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=7d

# LLM 配置
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=60

GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-pro

DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-chat

# SQL 执行配置
SQL_MAX_ROWS=1000
SQL_TIMEOUT=30
SQL_CACHE_TTL=3600

# 向量库配置
VECTOR_ENABLE=true
VECTOR_MODEL=text-embedding-3-small
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# 飞书配置
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 数据接入配置示例
DEMO_DB_HOST=localhost
DEMO_DB_PORT=5432
DEMO_DB_NAME=demo_db
DEMO_DB_USER=demo_user
DEMO_DB_PASSWORD=demo_password
