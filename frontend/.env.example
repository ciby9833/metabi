# 前端环境变量
# 注意：所有 NEXT_PUBLIC_ 开头的变量会暴露给浏览器

# 后端 API 地址（浏览器调用）
# 注意：不要带 /v1，前端服务层会自动拼接 /v1/...
# 改成你后端实际的端口（默认 3000，但你可能改成了 3050）
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# 应用名称
NEXT_PUBLIC_APP_NAME=ChatBI

# 默认用户标识（MVP 阶段没有登录，使用固定用户）
NEXT_PUBLIC_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000000
